import requests
import random
import json
import os
import msvcrt
from typing import List, Dict, Any

API_KEY = "your wot api key"
NICKNAME = "your wot nickname"
REGION = "eu"

MIN_TIER = 8
MAX_TIER = 11

HISTORY_SIZE = 20
HISTORY_FILE = "last_tanks.json"

BASE_URL = f"https://api.worldoftanks.{REGION}/wot"

last_played: List[int] = []


def load_history() -> List[int]:
    if os.path.exists(HISTORY_FILE):
        try:
            with open(HISTORY_FILE, "r") as f:
                return [int(x) for x in json.load(f)]
        except Exception:
            pass
    return []


def save_history(history: List[int]) -> None:
    with open(HISTORY_FILE, "w") as f:
        json.dump(history, f)


def get_account_id() -> int:
    resp = requests.get(
        f"{BASE_URL}/account/list/",
        params={
            "application_id": API_KEY,
            "search": NICKNAME,
            "limit": 1,
        },
        timeout=10,
    ).json()

    if resp.get("status") != "ok" or not resp.get("data"):
        raise RuntimeError("Player not found")

    return resp["data"][0]["account_id"]


print("Loading account...")

account_id = get_account_id()

print(f"Account ID: {account_id}")

print("Downloading tank stats...")

stats_resp = requests.get(
    f"{BASE_URL}/tanks/stats/",
    params={
        "application_id": API_KEY,
        "account_id": account_id,
    },
    timeout=15,
).json()

tank_data = stats_resp["data"].get(str(account_id), [])

if not tank_data:
    raise RuntimeError("No tank statistics found")

print("Downloading vehicle encyclopedia...")

vehicle_resp = requests.get(
    f"{BASE_URL}/encyclopedia/vehicles/",
    params={
        "application_id": API_KEY
    },
    timeout=30,
).json()

vehicle_data = vehicle_resp.get("data", {})

last_played = load_history()

eligible_tanks = []

for entry in tank_data:

    stats = entry.get("all", {})

    battles = stats.get("battles", 0)
    wins = stats.get("wins", 0)

    if battles <= 0:
        continue

    winrate = wins / battles * 100

    if winrate >= 50:
        continue

    tank_id = entry["tank_id"]

    vehicle = vehicle_data.get(str(tank_id))

    if not vehicle:
        continue

    tier = vehicle.get("tier", 0)

    if not (MIN_TIER <= tier <= MAX_TIER):
        continue

    eligible_tanks.append(
        {
            "tank_id": tank_id,
            "name": vehicle.get("name"),
            "tier": tier,
            "type": vehicle.get("type"),
            "nation": vehicle.get("nation"),
            "battles": battles,
            "wins": wins,
            "winrate": winrate,
        }
    )

if not eligible_tanks:
    raise RuntimeError("No eligible tanks found")

print(f"Loaded {len(eligible_tanks)} eligible tanks.")


def pick_tank() -> Dict[str, Any]:

    available = [
        tank
        for tank in eligible_tanks
        if tank["tank_id"] not in last_played
    ]

    if len(available) < 3:
        available = eligible_tanks

    weights = [
        max(100 - tank["winrate"], 1)
        for tank in available
    ]

    chosen = random.choices(
        available,
        weights=weights,
        k=1,
    )[0]

    last_played.append(chosen["tank_id"])

    if len(last_played) > HISTORY_SIZE:
        last_played.pop(0)

    save_history(last_played)

    return chosen


while True:

    tank = pick_tank()

    print("\n" + "=" * 50)
    print("🎲 RANDOM TANK")
    print("=" * 50)

    print(f"Name    : {tank['name']}")
    print(f"Tier    : {tank['tier']}")
    print(f"Type    : {tank['type']}")
    print(f"Nation  : {tank['nation']}")
    print(f"Battles : {tank['battles']:,}")
    print(f"Wins    : {tank['wins']:,}")
    print(f"WR      : {tank['winrate']:.2f}%")
    print(f"History : {len(last_played)}/{HISTORY_SIZE}")

    print("\n[Any key] Another tank")
    print("[Q] Quit")

    key = msvcrt.getch().lower()

    if key == b"q":
        break
